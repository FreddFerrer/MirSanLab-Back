# MySQL
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=mirsan_db
MYSQL_USER=user
MYSQL_PASSWORD=change_me_db_password
MYSQL_PORT=3307

# Backend
BACKEND_PORT=8080
SERVER_PORT=8080
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# JWT
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_EXPIRATION=86400000

# SMTP
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@example.com
SPRING_MAIL_PASSWORD=your_app_password
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true

# Email branding (optional)
MAIL_BRAND_NAME=MirsanLab
MAIL_CONTACT_EMAIL=
MAIL_CONTACT_PHONE=

# Bootstrap admin (activar solo primer arranque)
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=admin@your-domain.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_NAME=Administrador
BOOTSTRAP_ADMIN_PHONE=

# CORS (lista separada por coma)
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200
APP_CORS_ALLOWED_ORIGIN_PATTERNS=
APP_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
APP_CORS_ALLOWED_HEADERS=*
APP_CORS_ALLOW_CREDENTIALS=true
APP_CORS_MAX_AGE=3600

# Resultados (archivos PDF)
RESULTADOS_STORAGE_PATH=/app/archivos
RESULTADOS_STORAGE_HOST_PATH=./archivos
