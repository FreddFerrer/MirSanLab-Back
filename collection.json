                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Paciente Demo\",\n  \"email\": \"paciente.demo@mail.com\",\n  \"password\": \"Clave123\",\n  \"telefono\": \"3624000000\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
